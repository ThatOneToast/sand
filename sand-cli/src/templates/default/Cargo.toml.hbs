[package]
name = "{{name}}"
version = "0.1.0"
edition = "2024"

[lib]
name = "{{name_snake}}"
path = "src/lib.rs"

[[bin]]
name = "sand_export"
path = "src/bin/sand_export.rs"

{{#if resourcepack}}
[[bin]]
name = "sand_resource_export"
path = "src/bin/sand_resource_export.rs"

{{/if}}
[dependencies]
{{#if use_path_deps}}
{{#if resourcepack}}
sand = { path = "{{sand_path}}", features = ["resourcepack"] }
{{else}}
sand = { path = "{{sand_path}}" }
{{/if}}
{{else}}
{{#if resourcepack}}
sand = { git = "{{sand_git_url}}", branch = "main", features = ["resourcepack"] }
{{else}}
sand = { git = "{{sand_git_url}}", branch = "main" }
{{/if}}
{{/if}}

[build-dependencies]
{{#if use_path_deps}}
sand-build = { path = "{{sand_build_path}}" }
{{else}}
sand-build = { git = "{{sand_git_url}}", branch = "main" }
{{/if}}
