[package]
name = "{{name}}"
version = "0.1.0"
edition = "2024"

[lib]
name = "{{name_snake}}"
path = "src/lib.rs"

[[bin]]
name = "sand_export"
path = "src/bin/sand_export.rs"

{{#if resourcepack}}
[[bin]]
name = "sand_resource_export"
path = "src/bin/sand_resource_export.rs"

{{/if}}
[dependencies]
{{#if use_path_deps}}
sand-core   = { path = "{{sand_core_path}}" }
{{#if resourcepack}}
sand-macros = { path = "{{sand_macros_path}}", features = ["resourcepack"] }
sand-resourcepack = { path = "{{sand_resourcepack_path}}" }
{{else}}
sand-macros = { path = "{{sand_macros_path}}" }
{{/if}}
{{else}}
sand-core   = "{{sand_version}}"
{{#if resourcepack}}
sand-macros = { version = "{{sand_version}}", features = ["resourcepack"] }
sand-resourcepack = "{{sand_version}}"
{{else}}
sand-macros = "{{sand_version}}"
{{/if}}
{{/if}}
serde_json = "1"

[build-dependencies]
{{#if use_path_deps}}
sand-build = { path = "{{sand_build_path}}" }
{{else}}
sand-build = "{{sand_version}}"
{{/if}}
