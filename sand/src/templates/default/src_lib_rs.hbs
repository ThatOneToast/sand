//! # {{name}}
//!
//! A Minecraft {{mc_version}} datapack built with [Sand](https://crates.io/crates/sand).

use sand_core::prelude::*;
{{#if resourcepack}}
use sand_macros::{component, function, hud_bar, hud_element, texture};
{{else}}
use sand_macros::{component, function};
{{/if}}

// -- State ------------------------------------------------------------------

static PLAYER_DATA: StorageVar<i32> = StorageVar::new("{{namespace}}:data", "player.mana");

// -- Functions -------------------------------------------------------------

/// Broadcasts a welcome message to all players.
///
/// Automatically written to `data/{{namespace}}/function/hello_world.mcfunction`
/// by `sand build`.
#[function]
pub fn hello_world() {
    cmd::tellraw(
        Selector::all_players(),
        Text::new("Welcome to {{name}}!").gold().bold(true),
    );
}

// -- Components ------------------------------------------------------------

/// Fires `{{namespace}}:hello_world` the first tick after a player joins.
///
/// Automatically written to `data/{{namespace}}/advancement/player_join.json`
/// by `sand build`.
#[component]
pub fn player_join() -> sand_core::Advancement {
    use sand_core::{Advancement, AdvancementRewards, AdvancementTrigger, Criterion};
    Advancement::new("{{namespace}}:player_join".parse().unwrap())
        .criterion("tick", Criterion::new(AdvancementTrigger::Tick))
        .rewards(AdvancementRewards::new().function("{{namespace}}:hello_world"))
}

// -- Datapack export hook -- required by `sand build`, do not remove -------

/// Invoked by the generated `sand_export` binary.
///
/// Calling this function from the binary forces the linker to include this
/// library's object file, which is required for `inventory::submit!`
/// constructor functions to run before `main`.
///
/// If you add components in separate modules, re-export them here with
/// `pub use my_module::*;` to ensure they are also linked.
#[doc(hidden)]
pub fn __sand_export(namespace: &str, mc_version: &str) {
    // Resolve the version profile and gate components against it.
    let resolved = match sand_core::version::resolve_export_caps(mc_version) {
        Ok(resolved) => resolved,
        Err(e) => {
            eprintln!("sand export failed: {e}");
            std::process::exit(1);
        }
    };
    match sand_core::try_export_components_json_for_version(
        namespace,
        &resolved.caps,
        &resolved.version,
        resolved.is_fallback,
    ) {
        Ok(json) => println!("{json}"),
        Err(e) => {
            eprintln!("sand export failed: {e}");
            std::process::exit(1);
        }
    }
}

{{#if resourcepack}}
// -- Resource pack export hook -- required by `sand build --resourcepack` ----

/// Invoked by `src/bin/sand_resource_export.rs` to collect all registered
/// resource pack components (`hud_bar!`, `hud_element!`, `texture!`).
///
/// If you add resource pack components in separate modules, re-export them
/// here with `pub use my_module::*;` to ensure they are linked.
#[doc(hidden)]
pub fn __sand_resource_export(namespace: &str) {
    println!("{}", sand_resourcepack::export_resourcepack_json(namespace));
}

// -- Resource pack components -----------------------------------------------
//
// Register HUD elements and textures here. Each macro call is automatically
// collected by `sand build --resourcepack` via the inventory registration.
//
// Example — health bar from a PNG (unicode is auto-assigned):
//
//   hud_bar!(
//       name: "health",
//       texture: "src/assets/health_bar.png",
//       steps: 10,
//       height: 9,
//       ascent: 9,
//   );
//
// Example — health bar with programmatic sprite strip:
//
//   hud_bar!(
//       name: "health",
//       texture: gen!(fill: 0xFF4444FF, empty: 0x333333FF),
//       steps: 10,
//       height: 9,
//       ascent: 9,
//   );
//
// Example — static overlay (unicode is auto-assigned):
//
//   hud_element!(
//       name: "hotbar_bg",
//       texture: "src/assets/hotbar.png",
//       height: 22,
//       ascent: -10,
//   );
//
// Example — static overlay with programmatic solid-color texture:
//
//   hud_element!(
//       name: "dark_overlay",
//       texture: gen!(color: 0x00000080),
//       height: 22,
//       ascent: -10,
//   );
//
// Example — raw texture:
//
//   texture!(
//       id: "{{namespace}}:item/my_item",
//       path: "src/assets/my_item.png",
//   );

