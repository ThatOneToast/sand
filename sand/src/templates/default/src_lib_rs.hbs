/// Broadcasts a welcome message to all players.
///
/// Automatically written to `data/{{namespace}}/function/hello_world.mcfunction`
/// by `sand build`.
#[function]
pub fn hello_world() {
    mcfunction! {
        r#"tellraw @a {"text":"Welcome to {{name}}!","color":"gold","bold":true}"#;
        "playsound minecraft:ui.toast.challenge_complete master @a ~ ~ ~ 1 1";
    }
}

