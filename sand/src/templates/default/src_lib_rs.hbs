/// Fires `{{namespace}}:hello_world` the first tick after a player joins.
///
/// Automatically written to `data/{{namespace}}/advancement/player_join.json`
/// by `sand build`.
#[component]
pub fn player_join() -> sand_core::Advancement {
    use sand_core::{Advancement, AdvancementRewards, AdvancementTrigger, Criterion};
    Advancement::new("{{namespace}}:player_join".parse().unwrap())
        .criterion("tick", Criterion::new(AdvancementTrigger::Tick))
        .rewards(AdvancementRewards::new().function("{{namespace}}:hello_world"))
}

